{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentkernel.dev/schemas/requirements-traceability-1.1.0.json",
  "title": "AgentKernel requirements traceability manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "metadata", "requirements"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/requirement"}
    }
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "stringArray": {
      "type": "array",
      "items": {"$ref": "#/$defs/nonEmptyString"},
      "uniqueItems": true
    },
    "statusCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "implemented and verified",
        "partially implemented",
        "missing",
        "blocked"
      ],
      "properties": {
        "implemented and verified": {"type": "integer", "minimum": 0},
        "partially implemented": {"type": "integer", "minimum": 0},
        "missing": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "source_document",
        "source_sha256",
        "source_line_count",
        "baseline_commit",
        "baseline_date",
        "id_policy",
        "allowed_statuses",
        "source_row_count",
        "catalog_row_count",
        "total_row_count",
        "status_counts",
        "release_readiness",
        "release_readiness_reasons"
      ],
      "properties": {
        "project": {"const": "AgentKernel"},
        "source_document": {"const": "AgentKernel_Full_Project_Specification.md"},
        "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_line_count": {"type": "integer", "minimum": 1},
        "baseline_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "baseline_date": {"type": "string", "format": "date"},
        "id_policy": {"$ref": "#/$defs/nonEmptyString"},
        "allowed_statuses": {
          "type": "array",
          "prefixItems": [
            {"const": "implemented and verified"},
            {"const": "partially implemented"},
            {"const": "missing"},
            {"const": "blocked"}
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "source_row_count": {"type": "integer", "minimum": 0},
        "catalog_row_count": {"type": "integer", "minimum": 0},
        "total_row_count": {"type": "integer", "minimum": 1},
        "status_counts": {"$ref": "#/$defs/statusCounts"},
        "release_readiness": {"enum": ["PASS", "FAIL"]},
        "release_readiness_reasons": {"$ref": "#/$defs/stringArray"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "document",
        "section",
        "line_start",
        "line_end",
        "keyword",
        "occurrence",
        "quote"
      ],
      "properties": {
        "kind": {"enum": ["specification", "user-objective"]},
        "document": {"$ref": "#/$defs/nonEmptyString"},
        "section": {"$ref": "#/$defs/nonEmptyString"},
        "line_start": {"type": ["integer", "null"], "minimum": 1},
        "line_end": {"type": ["integer", "null"], "minimum": 1},
        "keyword": {"type": ["string", "null"]},
        "occurrence": {"type": ["integer", "null"], "minimum": 1},
        "quote": {"$ref": "#/$defs/nonEmptyString"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "specification"}}},
          "then": {
            "properties": {
              "line_start": {"type": "integer", "minimum": 1},
              "line_end": {"type": "integer", "minimum": 1}
            }
          },
          "else": {
            "properties": {
              "line_start": {"type": "null"},
              "line_end": {"type": "null"},
              "keyword": {"type": "null"},
              "occurrence": {"type": "null"}
            }
          }
        }
      ]
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "mandatory",
        "normative_class",
        "category",
        "source",
        "release_gate",
        "component",
        "profile",
        "platform",
        "dependencies",
        "pass_condition",
        "verification_method",
        "artifact",
        "implementation_evidence",
        "verification_evidence",
        "status",
        "blocker_reason",
        "blocker_action",
        "related_ids",
        "last_verified_commit",
        "last_verified_date",
        "baseline_source_row"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"},
        "summary": {"$ref": "#/$defs/nonEmptyString"},
        "mandatory": {"type": "boolean"},
        "normative_class": {"$ref": "#/$defs/nonEmptyString"},
        "category": {"$ref": "#/$defs/nonEmptyString"},
        "source": {"$ref": "#/$defs/source"},
        "release_gate": {"$ref": "#/$defs/stringArray"},
        "component": {"$ref": "#/$defs/stringArray"},
        "profile": {"$ref": "#/$defs/stringArray"},
        "platform": {"$ref": "#/$defs/stringArray"},
        "dependencies": {"$ref": "#/$defs/stringArray"},
        "pass_condition": {"$ref": "#/$defs/nonEmptyString"},
        "verification_method": {"$ref": "#/$defs/nonEmptyString"},
        "artifact": {"$ref": "#/$defs/stringArray"},
        "implementation_evidence": {"$ref": "#/$defs/stringArray"},
        "verification_evidence": {"$ref": "#/$defs/stringArray"},
        "status": {
          "enum": [
            "implemented and verified",
            "partially implemented",
            "missing",
            "blocked"
          ]
        },
        "blocker_reason": {"type": "string"},
        "blocker_action": {"type": "string"},
        "related_ids": {"$ref": "#/$defs/stringArray"},
        "last_verified_commit": {
          "type": "string",
          "pattern": "^(?:|[0-9a-f]{40})$"
        },
        "last_verified_date": {
          "anyOf": [{"const": ""}, {"type": "string", "format": "date"}]
        },
        "baseline_source_row": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "implemented and verified"}}},
          "then": {
            "properties": {
              "implementation_evidence": {"minItems": 1},
              "verification_evidence": {"minItems": 1},
              "last_verified_commit": {"pattern": "^[0-9a-f]{40}$"},
              "last_verified_date": {"type": "string", "format": "date", "minLength": 10}
            }
          }
        },
        {
          "if": {"properties": {"status": {"const": "partially implemented"}}},
          "then": {"properties": {"implementation_evidence": {"minItems": 1}}}
        },
        {
          "if": {"properties": {"status": {"const": "blocked"}}},
          "then": {
            "properties": {
              "blocker_reason": {"minLength": 1},
              "blocker_action": {"minLength": 1}
            }
          },
          "else": {
            "properties": {
              "blocker_reason": {"const": ""},
              "blocker_action": {"const": ""}
            }
          }
        }
      ]
    }
  }
}
