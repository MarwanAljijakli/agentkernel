    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "effect_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Effect Digest",
      "type": "string"
    },
    "intent_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Intent Hash",
      "type": "string"
    },
    "operation": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Operation",
      "type": "string"
    },
    "receipt_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Receipt Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "target_version_after": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Target Version After",
      "type": "string"
    },
    "target_version_before": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Target Version Before",
      "type": "string"
    },
    "transaction_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Transaction Id",
      "type": "string"
    }
