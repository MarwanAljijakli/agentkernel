{
  "$defs": {
    "IntendedOutcome": {
      "enum": [
        "ABORTED",
        "STALE_STATE"
      ],
      "title": "IntendedOutcome",
      "type": "string"
    },
    "TransactionState": {
      "description": "Normative durable transaction states from specification Section 8.2.",
      "enum": [
        "NEW",
        "PLANNED",
        "REJECTED",
        "AUTHORIZED_TO_STAGE",
        "STAGING",
        "STAGED",
        "STAGE_VERIFIED",
        "AWAITING_APPROVAL",
        "READY_TO_COMMIT",
        "COMMITTING",
        "COMMITTED",
        "FAILED",
        "ABORTING",
        "ABORTED",
        "STALE_STATE",
        "ROLLING_BACK",
        "ROLLED_BACK",
        "COMPENSATING",
        "COMPENSATED",
        "COMPENSATION_FAILED",
        "RECOVERY_FAILED",
        "IN_DOUBT",
        "RECONCILING"
      ],
      "title": "TransactionState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "adapter_manifest_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Adapter Manifest Digest"
    },
    "capability_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Capability Digest"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "intended_outcome": {
      "anyOf": [
        {
          "$ref": "#/$defs/IntendedOutcome"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "intent_hash": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Intent Hash"
    },
    "policy_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Digest"
    },
    "reason_code": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reason Code"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/TransactionState",
      "default": "NEW"
    },
    "supersedes_transaction_id": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Supersedes Transaction Id"
    },
    "transaction_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Transaction Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "version": {
      "default": 0,
      "minimum": 0,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "transaction_id",
    "goal_id",
    "created_at",
    "updated_at"
  ],
  "title": "TransactionRecord",
  "type": "object"
}
