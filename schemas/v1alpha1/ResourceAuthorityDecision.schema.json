{
  "$defs": {
    "AuthorityEvaluationVerdict": {
      "description": "Fail-closed result of the enforced authority evaluator.",
      "enum": [
        "ALLOW",
        "DENY"
      ],
      "title": "AuthorityEvaluationVerdict",
      "type": "string"
    },
    "AuthorityReasonCode": {
      "description": "Stable, evidence-safe reasons emitted by the pure evaluator.",
      "enum": [
        "AUTHORITY_GRANTED",
        "AUTHORITY_MISSING",
        "ACTION_CONTEXT_MISMATCH",
        "SNAPSHOT_MISMATCH",
        "SNAPSHOT_FROM_FUTURE",
        "SNAPSHOT_STALE",
        "TENANT_MISMATCH",
        "SUBJECT_MISMATCH",
        "AUDIENCE_MISMATCH",
        "GOAL_MISMATCH",
        "RUN_MISMATCH",
        "ROOT_ISSUER_MISMATCH",
        "UNKNOWN_KEY",
        "UNSUPPORTED_TOKEN_VERSION",
        "CAPABILITY_NOT_YET_VALID",
        "CAPABILITY_EXPIRED",
        "CAPABILITY_REVOKED",
        "CAPABILITY_BUDGET_STATE_MISSING",
        "CAPABILITY_BUDGET_STATE_MISMATCH",
        "CAPABILITY_BUDGET_EXHAUSTED",
        "CAPABILITY_RESERVATION_PLAN_TOO_LARGE",
        "AUTHORITY_COMPLEXITY_LIMIT",
        "DELEGATION_PARENT_MISSING",
        "DELEGATION_CYCLE",
        "DELEGATION_CHAIN_TOO_DEEP",
        "DELEGATION_ISSUER_MISMATCH",
        "DELEGATION_ACTION_WIDENED",
        "DELEGATION_RESOURCE_WIDENED",
        "DELEGATION_DATA_CLASS_WIDENED",
        "DELEGATION_TIME_WIDENED",
        "DELEGATION_DEPTH_INVALID",
        "DELEGATION_BUDGET_WIDENED",
        "ACTION_NOT_GRANTED",
        "RESOURCE_NOT_GRANTED",
        "RESOURCE_ALIAS_REJECTED",
        "DATA_CLASS_NOT_GRANTED",
        "WILDCARD_SCOPE_FORBIDDEN",
        "FORBIDDEN_RISK_CLASS",
        "PARTIAL_RESOURCE_DENIAL",
        "MULTIPLE_RESOURCE_DENIALS"
      ],
      "title": "AuthorityReasonCode",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Deterministic evidence for one independently authorized resource use.",
  "properties": {
    "authority_action": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Authority Action",
      "type": "string"
    },
    "canonical_resource": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Canonical Resource",
      "type": "string"
    },
    "capability_chain_ids": {
      "default": [],
      "items": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
        "type": "string"
      },
      "maxItems": 65,
      "title": "Capability Chain Ids",
      "type": "array"
    },
    "data_classes": {
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 64,
      "title": "Data Classes",
      "type": "array"
    },
    "evidence_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Evidence Digest",
      "type": "string"
    },
    "provenance_ids": {
      "items": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
        "type": "string"
      },
      "maxItems": 256,
      "title": "Provenance Ids",
      "type": "array"
    },
    "reason_code": {
      "$ref": "#/$defs/AuthorityReasonCode"
    },
    "resource_index": {
      "minimum": 0,
      "title": "Resource Index",
      "type": "integer"
    },
    "resource_use_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Resource Use Digest",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/AuthorityEvaluationVerdict"
    }
  },
  "required": [
    "resource_index",
    "resource_use_digest",
    "authority_action",
    "canonical_resource",
    "data_classes",
    "provenance_ids",
    "verdict",
    "reason_code",
    "evidence_digest"
  ],
  "title": "ResourceAuthorityDecision",
  "type": "object"
}
