{
  "additionalProperties": false,
  "properties": {
    "api_version": {
      "const": "agentkernel.io/v1alpha1",
      "default": "agentkernel.io/v1alpha1",
      "title": "Api Version",
      "type": "string"
    },
    "budget": {
      "additionalProperties": {
        "minimum": 0,
        "type": "integer"
      },
      "title": "Budget",
      "type": "object"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "deadline": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Deadline"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "principal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Principal Id",
      "type": "string"
    },
    "resource_scope": {
      "default": [],
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "title": "Resource Scope",
      "type": "array"
    },
    "text": {
      "maxLength": 32768,
      "minLength": 1,
      "title": "Text",
      "type": "string"
    }
  },
  "required": [
    "goal_id",
    "principal_id",
    "text",
    "created_at"
  ],
  "title": "GoalRecord",
  "type": "object"
}
