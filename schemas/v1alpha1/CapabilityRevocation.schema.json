{
  "additionalProperties": false,
  "description": "A durable revocation by capability ID, nonce, or both.",
  "properties": {
    "capability_id": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Capability Id"
    },
    "effective_at": {
      "format": "date-time",
      "title": "Effective At",
      "type": "string"
    },
    "nonce": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Nonce"
    },
    "reason": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Reason",
      "type": "string"
    },
    "revocation_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Revocation Id",
      "type": "string"
    },
    "tenant_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "revocation_id",
    "tenant_id",
    "effective_at",
    "reason"
  ],
  "title": "CapabilityRevocation",
  "type": "object"
}
