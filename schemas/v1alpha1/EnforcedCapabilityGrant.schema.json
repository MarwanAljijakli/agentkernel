{
  "additionalProperties": false,
  "description": "A content-bound capability record admitted to the enforced authority snapshot.",
  "properties": {
    "actions": {
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Actions",
      "type": "array"
    },
    "audience": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Audience",
      "type": "string"
    },
    "capability_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Capability Id",
      "type": "string"
    },
    "data_classes": {
      "default": [],
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Data Classes",
      "type": "array"
    },
    "delegation_depth_remaining": {
      "default": 0,
      "maximum": 64,
      "minimum": 0,
      "title": "Delegation Depth Remaining",
      "type": "integer"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "grant_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Grant Digest",
      "type": "string"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "issuer": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Issuer",
      "type": "string"
    },
    "key_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Key Id",
      "type": "string"
    },
    "max_uses": {
      "minimum": 1,
      "title": "Max Uses",
      "type": "integer"
    },
    "nonce": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Nonce",
      "type": "string"
    },
    "not_before": {
      "format": "date-time",
      "title": "Not Before",
      "type": "string"
    },
    "parent_capability": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Capability"
    },
    "resource_scopes": {
      "items": {
        "maxLength": 8192,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Resource Scopes",
      "type": "array"
    },
    "run_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "subject": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Subject",
      "type": "string"
    },
    "tenant_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Tenant Id",
      "type": "string"
    },
    "token_version": {
      "minimum": 1,
      "title": "Token Version",
      "type": "integer"
    }
  },
  "required": [
    "tenant_id",
    "capability_id",
    "token_version",
    "key_id",
    "issuer",
    "subject",
    "audience",
    "goal_id",
    "run_id",
    "actions",
    "resource_scopes",
    "issued_at",
    "not_before",
    "expires_at",
    "max_uses",
    "nonce",
    "grant_digest"
  ],
  "title": "EnforcedCapabilityGrant",
  "type": "object"
}
