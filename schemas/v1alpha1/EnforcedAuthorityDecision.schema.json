{
  "$defs": {
    "AuthorityEvaluationVerdict": {
      "description": "Fail-closed result of the enforced authority evaluator.",
      "enum": [
        "ALLOW",
        "DENY"
      ],
      "title": "AuthorityEvaluationVerdict",
      "type": "string"
    },
    "AuthorityReasonCode": {
      "description": "Stable, evidence-safe reasons emitted by the pure evaluator.",
      "enum": [
        "AUTHORITY_GRANTED",
        "AUTHORITY_MISSING",
        "ACTION_CONTEXT_MISMATCH",
        "SNAPSHOT_MISMATCH",
        "SNAPSHOT_FROM_FUTURE",
        "SNAPSHOT_STALE",
        "TENANT_MISMATCH",
        "SUBJECT_MISMATCH",
        "AUDIENCE_MISMATCH",
        "GOAL_MISMATCH",
        "RUN_MISMATCH",
        "ROOT_ISSUER_MISMATCH",
        "UNKNOWN_KEY",
        "UNSUPPORTED_TOKEN_VERSION",
        "CAPABILITY_NOT_YET_VALID",
        "CAPABILITY_EXPIRED",
        "CAPABILITY_REVOKED",
        "CAPABILITY_BUDGET_STATE_MISSING",
        "CAPABILITY_BUDGET_STATE_MISMATCH",
        "CAPABILITY_BUDGET_EXHAUSTED",
        "CAPABILITY_RESERVATION_PLAN_TOO_LARGE",
        "AUTHORITY_COMPLEXITY_LIMIT",
        "DELEGATION_PARENT_MISSING",
        "DELEGATION_CYCLE",
        "DELEGATION_CHAIN_TOO_DEEP",
        "DELEGATION_ISSUER_MISMATCH",
        "DELEGATION_ACTION_WIDENED",
        "DELEGATION_RESOURCE_WIDENED",
        "DELEGATION_DATA_CLASS_WIDENED",
        "DELEGATION_TIME_WIDENED",
        "DELEGATION_DEPTH_INVALID",
        "DELEGATION_BUDGET_WIDENED",
        "ACTION_NOT_GRANTED",
        "RESOURCE_NOT_GRANTED",
        "RESOURCE_ALIAS_REJECTED",
        "DATA_CLASS_NOT_GRANTED",
        "WILDCARD_SCOPE_FORBIDDEN",
        "FORBIDDEN_RISK_CLASS",
        "PARTIAL_RESOURCE_DENIAL",
        "MULTIPLE_RESOURCE_DENIALS"
      ],
      "title": "AuthorityReasonCode",
      "type": "string"
    },
    "CapabilityReservationPlan": {
      "additionalProperties": false,
      "description": "A deterministic all-or-none budget reservation request for the durable store.",
      "properties": {
        "authority_snapshot_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Authority Snapshot Digest",
          "type": "string"
        },
        "capability_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
            "type": "string"
          },
          "maxItems": 256,
          "minItems": 1,
          "title": "Capability Ids",
          "type": "array"
        },
        "intent_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Intent Hash",
          "type": "string"
        },
        "plan_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Plan Digest",
          "type": "string"
        },
        "tenant_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "title": "Tenant Id",
          "type": "string"
        },
        "transaction_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "title": "Transaction Id",
          "type": "string"
        },
        "units_per_capability": {
          "const": 1,
          "default": 1,
          "title": "Units Per Capability",
          "type": "integer"
        }
      },
      "required": [
        "tenant_id",
        "transaction_id",
        "intent_hash",
        "authority_snapshot_digest",
        "capability_ids",
        "plan_digest"
      ],
      "title": "CapabilityReservationPlan",
      "type": "object"
    },
    "ResourceAuthorityDecision": {
      "additionalProperties": false,
      "description": "Deterministic evidence for one independently authorized resource use.",
      "properties": {
        "authority_action": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Authority Action",
          "type": "string"
        },
        "canonical_resource": {
          "maxLength": 8192,
          "minLength": 1,
          "title": "Canonical Resource",
          "type": "string"
        },
        "capability_chain_ids": {
          "default": [],
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
            "type": "string"
          },
          "maxItems": 65,
          "title": "Capability Chain Ids",
          "type": "array"
        },
        "data_classes": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 64,
          "title": "Data Classes",
          "type": "array"
        },
        "evidence_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Evidence Digest",
          "type": "string"
        },
        "provenance_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
            "type": "string"
          },
          "maxItems": 256,
          "title": "Provenance Ids",
          "type": "array"
        },
        "reason_code": {
          "$ref": "#/$defs/AuthorityReasonCode"
        },
        "resource_index": {
          "minimum": 0,
          "title": "Resource Index",
          "type": "integer"
        },
        "resource_use_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Resource Use Digest",
          "type": "string"
        },
        "verdict": {
          "$ref": "#/$defs/AuthorityEvaluationVerdict"
        }
      },
      "required": [
        "resource_index",
        "resource_use_digest",
        "authority_action",
        "canonical_resource",
        "data_classes",
        "provenance_ids",
        "verdict",
        "reason_code",
        "evidence_digest"
      ],
      "title": "ResourceAuthorityDecision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Whole-action authority result, including reproducible per-resource evidence.",
  "properties": {
    "authority_snapshot_as_of": {
      "format": "date-time",
      "title": "Authority Snapshot As Of",
      "type": "string"
    },
    "authority_snapshot_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Authority Snapshot Digest",
      "type": "string"
    },
    "authority_snapshot_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Authority Snapshot Id",
      "type": "string"
    },
    "authority_snapshot_revision": {
      "minimum": 1,
      "title": "Authority Snapshot Revision",
      "type": "integer"
    },
    "authority_snapshot_tenant_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Authority Snapshot Tenant Id",
      "type": "string"
    },
    "decision_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Decision Digest",
      "type": "string"
    },
    "evaluated_at": {
      "format": "date-time",
      "title": "Evaluated At",
      "type": "string"
    },
    "evaluation_context_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Evaluation Context Digest",
      "type": "string"
    },
    "expected_authority_snapshot_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Expected Authority Snapshot Digest",
      "type": "string"
    },
    "intent_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Intent Hash",
      "type": "string"
    },
    "provenance_used_as_authority": {
      "const": false,
      "default": false,
      "title": "Provenance Used As Authority",
      "type": "boolean"
    },
    "reason_code": {
      "$ref": "#/$defs/AuthorityReasonCode"
    },
    "reservation_plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/CapabilityReservationPlan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "resource_decisions": {
      "items": {
        "$ref": "#/$defs/ResourceAuthorityDecision"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Resource Decisions",
      "type": "array"
    },
    "tenant_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Tenant Id",
      "type": "string"
    },
    "transaction_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Transaction Id",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/AuthorityEvaluationVerdict"
    }
  },
  "required": [
    "tenant_id",
    "transaction_id",
    "intent_hash",
    "authority_snapshot_tenant_id",
    "authority_snapshot_id",
    "authority_snapshot_revision",
    "authority_snapshot_as_of",
    "authority_snapshot_digest",
    "expected_authority_snapshot_digest",
    "evaluation_context_digest",
    "evaluated_at",
    "verdict",
    "reason_code",
    "resource_decisions",
    "decision_digest"
  ],
  "title": "EnforcedAuthorityDecision",
  "type": "object"
}
