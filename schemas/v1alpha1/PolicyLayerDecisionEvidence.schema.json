{
  "$defs": {
    "PolicyDecision": {
      "additionalProperties": false,
      "properties": {
        "allowed_modes": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 16,
          "title": "Allowed Modes",
          "type": "array"
        },
        "blocking_unknown_facts": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 256,
          "title": "Blocking Unknown Facts",
          "type": "array"
        },
        "blocking_unknown_rules": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Blocking Unknown Rules",
          "type": "array"
        },
        "bundle_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Bundle Digest",
          "type": "string"
        },
        "matched_approvals": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Matched Approvals",
          "type": "array"
        },
        "matched_denials": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Matched Denials",
          "type": "array"
        },
        "matched_grants": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Matched Grants",
          "type": "array"
        },
        "matched_shadows": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Matched Shadows",
          "type": "array"
        },
        "obligations": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2,
          "title": "Obligations",
          "type": "array"
        },
        "reason_code": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Reason Code",
          "type": "string"
        },
        "unknown_facts": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 256,
          "title": "Unknown Facts",
          "type": "array"
        },
        "unknown_rules": {
          "default": [],
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 2048,
          "title": "Unknown Rules",
          "type": "array"
        },
        "verdict": {
          "$ref": "#/$defs/PolicyVerdict"
        }
      },
      "required": [
        "verdict",
        "reason_code",
        "bundle_digest"
      ],
      "title": "PolicyDecision",
      "type": "object"
    },
    "PolicyLayer": {
      "description": "Normative policy layers in their evidence-rendering order.",
      "enum": [
        "system",
        "deployment",
        "tenant",
        "user",
        "goal",
        "adapter",
        "data"
      ],
      "title": "PolicyLayer",
      "type": "string"
    },
    "PolicyLayerIdentity": {
      "additionalProperties": false,
      "description": "Immutable identity of one compiled bundle at one policy layer.",
      "properties": {
        "bundle_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Bundle Digest",
          "type": "string"
        },
        "bundle_name": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "title": "Bundle Name",
          "type": "string"
        },
        "bundle_version": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Bundle Version",
          "type": "string"
        },
        "layer": {
          "$ref": "#/$defs/PolicyLayer"
        },
        "scope_id": {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "title": "Scope Id",
          "type": "string"
        }
      },
      "required": [
        "layer",
        "scope_id",
        "bundle_name",
        "bundle_version",
        "bundle_digest"
      ],
      "title": "PolicyLayerIdentity",
      "type": "object"
    },
    "PolicyVerdict": {
      "enum": [
        "ELIGIBLE",
        "DENY",
        "ABSTAIN"
      ],
      "title": "PolicyVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "The complete deterministic result of one bundle for one resource use.",
  "properties": {
    "context_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Context Digest",
      "type": "string"
    },
    "decision": {
      "$ref": "#/$defs/PolicyDecision"
    },
    "decision_digest": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Decision Digest",
      "type": "string"
    },
    "identity": {
      "$ref": "#/$defs/PolicyLayerIdentity"
    },
    "input_unknown_facts": {
      "default": [],
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 256,
      "title": "Input Unknown Facts",
      "type": "array"
    },
    "resource_use_ref": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Resource Use Ref",
      "type": "string"
    },
    "unknown_facts": {
      "default": [],
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 256,
      "title": "Unknown Facts",
      "type": "array"
    }
  },
  "required": [
    "identity",
    "resource_use_ref",
    "context_digest",
    "decision",
    "decision_digest"
  ],
  "title": "PolicyLayerDecisionEvidence",
  "type": "object"
}
