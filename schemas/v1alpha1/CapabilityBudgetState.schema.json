{
  "additionalProperties": false,
  "description": "Read-only budget facts captured by the durable authority snapshot.",
  "properties": {
    "capability_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Capability Id",
      "type": "string"
    },
    "consumed_uses": {
      "default": 0,
      "minimum": 0,
      "title": "Consumed Uses",
      "type": "integer"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "max_uses": {
      "minimum": 1,
      "title": "Max Uses",
      "type": "integer"
    },
    "reserved_intent_hashes": {
      "default": [],
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Reserved Intent Hashes",
      "type": "array"
    },
    "reserved_uses": {
      "default": 0,
      "minimum": 0,
      "title": "Reserved Uses",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "tenant_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "tenant_id",
    "capability_id",
    "goal_id",
    "run_id",
    "max_uses"
  ],
  "title": "CapabilityBudgetState",
  "type": "object"
}
