{
  "$defs": {
    "VerificationStatus": {
      "enum": [
        "PASS",
        "FAIL",
        "UNKNOWN",
        "ERROR"
      ],
      "title": "VerificationStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "evidence_refs": {
      "default": [],
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "residual_effects": {
      "default": [],
      "items": {
        "maxLength": 512,
        "minLength": 1,
        "type": "string"
      },
      "title": "Residual Effects",
      "type": "array"
    },
    "restored_state_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Restored State Digest"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/VerificationStatus"
    },
    "strategy": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Strategy",
      "type": "string"
    }
  },
  "required": [
    "status",
    "strategy"
  ],
  "title": "RecoveryReport",
  "type": "object"
}
