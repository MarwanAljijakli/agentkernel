{
  "$defs": {
    "JsonValue": {}
  },
  "additionalProperties": false,
  "properties": {
    "adapter": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Adapter",
      "type": "string"
    },
    "adapter_version": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Adapter Version",
      "type": "string"
    },
    "agent_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Agent Id",
      "type": "string"
    },
    "api_version": {
      "const": "agentkernel.io/v1alpha1",
      "default": "agentkernel.io/v1alpha1",
      "title": "Api Version",
      "type": "string"
    },
    "arguments": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "maxProperties": 4096,
      "title": "Arguments",
      "type": "object"
    },
    "capability_refs": {
      "default": [],
      "items": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
        "type": "string"
      },
      "maxItems": 256,
      "title": "Capability Refs",
      "type": "array"
    },
    "deadline": {
      "format": "date-time",
      "title": "Deadline",
      "type": "string"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "idempotency_key": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Idempotency Key"
    },
    "operation": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Operation",
      "type": "string"
    },
    "provenance_ids": {
      "default": [],
      "items": {
        "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
        "type": "string"
      },
      "maxItems": 256,
      "title": "Provenance Ids",
      "type": "array"
    },
    "transaction_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Transaction Id",
      "type": "string"
    }
  },
  "required": [
    "goal_id",
    "transaction_id",
    "agent_id",
    "adapter",
    "adapter_version",
    "operation",
    "arguments",
    "deadline"
  ],
  "title": "ActionProposal",
  "type": "object"
}
