{
  "$defs": {
    "JsonValue": {}
  },
  "additionalProperties": false,
  "properties": {
    "actor": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Actor",
      "type": "string"
    },
    "artifact_refs": {
      "default": [],
      "items": {
        "pattern": "^sha256:[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "event_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Event Hash",
      "type": "string"
    },
    "event_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Event Type",
      "type": "string"
    },
    "logical_time": {
      "minimum": 0,
      "title": "Logical Time",
      "type": "integer"
    },
    "on_behalf_of": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "On Behalf Of",
      "type": "string"
    },
    "payload": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Payload",
      "type": "object"
    },
    "previous_event_hash": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Event Hash"
    },
    "run_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sequence": {
      "minimum": 0,
      "title": "Sequence",
      "type": "integer"
    },
    "signature_ref": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Signature Ref"
    },
    "transaction_id": {
      "anyOf": [
        {
          "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Transaction Id"
    },
    "wall_time": {
      "format": "date-time",
      "title": "Wall Time",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "run_id",
    "sequence",
    "logical_time",
    "wall_time",
    "event_type",
    "actor",
    "on_behalf_of",
    "event_hash"
  ],
  "title": "EventEnvelope",
  "type": "object"
}
