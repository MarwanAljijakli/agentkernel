  "required": [
    "capability_id",
    "key_id",
    "issuer",
    "subject",
    "audience",
    "goal_id",
    "run_id",
    "actions",
    "resources",
    "issued_at",
    "not_before",
    "expires_at",
    "nonce",
    "signature"
  ],
  "title": "CapabilityGrant",
  "type": "object"
}
