{
  "$defs": {
    "MessagePart": {
      "additionalProperties": false,
      "properties": {
        "data_classes": {
          "items": {
            "maxLength": 512,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 64,
          "minItems": 1,
          "title": "Data Classes",
          "type": "array"
        },
        "provenance_ids": {
          "items": {
            "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
            "type": "string"
          },
          "title": "Provenance Ids",
          "type": "array"
        },
        "provenance_trust": {
          "$ref": "#/$defs/ProvenanceTrust"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text",
        "provenance_ids",
        "provenance_trust",
        "data_classes"
      ],
      "title": "MessagePart",
      "type": "object"
    },
    "ProvenanceTrust": {
      "enum": [
        "trusted_control",
        "authorized_user",
        "project_data",
        "external_untrusted",
        "model_generated",
        "unknown"
      ],
      "title": "ProvenanceTrust",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Agent Id",
      "type": "string"
    },
    "external": {
      "title": "External",
      "type": "boolean"
    },
    "goal_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Goal Id",
      "type": "string"
    },
    "model": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "parts": {
      "items": {
        "$ref": "#/$defs/MessagePart"
      },
      "maxItems": 128,
      "minItems": 1,
      "title": "Parts",
      "type": "array"
    },
    "provider": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Provider",
      "type": "string"
    },
    "purpose": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "region": {
      "anyOf": [
        {
          "maxLength": 512,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Region"
    },
    "request_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Request Id",
      "type": "string"
    },
    "retention": {
      "default": "none",
      "maxLength": 512,
      "minLength": 1,
      "title": "Retention",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{0,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "token_budget": {
      "maximum": 1000000,
      "minimum": 1,
      "title": "Token Budget",
      "type": "integer"
    },
    "training_use": {
      "default": false,
      "title": "Training Use",
      "type": "boolean"
    }
  },
  "required": [
    "request_id",
    "goal_id",
    "run_id",
    "agent_id",
    "provider",
    "model",
    "purpose",
    "parts",
    "external",
    "token_budget"
  ],
  "title": "ModelInferenceRequest",
  "type": "object"
}
